  "info": {
    "_postman_id": "ccec1c15-9a43-4d40-9d63-5d1a6a7c8e2a",
    "name": "Springer Nature Meta API",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "description": {
      "content": "The Springer Nature Meta API (versioned metadata) provides comprehensive access to metadata for over 14 million scholarly documents including journal articles, book chapters, and conference papers. Supports search by keyword, author, journal, ISSN, ISBN, DOI, subject, and date range. Returns rich metadata including abstracts, author affiliations, funding, subject classification, and content links. Requires a free API key from dev.springernature.com.\n\nContact Support:\n Name: Springer Nature Developer Support",
      "type": "text/plain"
    }
  }
