                {
                  "disabled": false,
                  "key": "s",
                  "value": "1",
                  "description": "Start record number for pagination (1-based)"
                },
                {
                  "disabled": false,
                  "key": "p",
                  "value": "10",
                  "description": "Number of results per page (max 100)"
